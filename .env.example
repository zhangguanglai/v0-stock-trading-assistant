# Supabase 配置 (用户数据存储和认证)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Tushare Pro Token (用于获取历史K线和财务数据)
# 免费注册获取: https://tushare.pro/register
# 配置后可获取完整技术指标计算 (MA, MACD, RSI, KDJ, BOLL等)
# 不配置也可使用，但仅有实时行情，无历史指标
TUSHARE_TOKEN=your-tushare-pro-token

# 可选：分析工具
NEXT_PUBLIC_ANALYTICS_ID=optional
